// Règles de sécurité Firestore — à coller dans Firebase Console :
// Firestore Database → Règles → remplacer tout le contenu → Publier.
//
// Ouvre la collection "store" en lecture/écriture (usage privé familial).
// Le reste de la base reste fermé par défaut.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /store/{docId} {
      allow read, write: if true;
    }
  }
}
